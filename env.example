# ─── Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Affiliate IDs ────────────────────────────────────────────────
# Amazon Associates — sign up: https://affiliate-program.amazon.com
AMAZON_AFFILIATE_TAG=buildkit-20

# eBay Partner Network — sign up: https://partnernetwork.ebay.com
EBAY_CAMPAIGN_ID=your-ebay-campaign-id

# Summit Racing — sign up: https://www.summitracing.com/info/affiliate
SUMMIT_AFFILIATE_ID=your-summit-id

# RockAuto — sign up: https://www.rockauto.com/en/affiliate/
ROCKAUTO_AFFILIATE_ID=your-rockauto-id

# CJ Affiliate (covers AutoZone, Advance Auto, etc.)
# sign up: https://www.cj.com
CJ_AFFILIATE_ID=your-cj-id

# ─── Analytics (optional) ─────────────────────────────────────────
# Used to track which affiliate links convert
# Set to any string to enable click logging to console/DB
ENABLE_CLICK_TRACKING=true

# ─── CORS ─────────────────────────────────────────────────────────
# Your frontend URL — change for production
FRONTEND_URL=http://localhost:5173
